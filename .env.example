# ─── OpenBenchML Environment Configuration ────────────────────────────────────
# Copy this file to .env and update values for your deployment.

# ─── Application ──────────────────────────────────────────────────────────────
DEBUG=True
APP_URL=http://localhost:8000
SECRET_KEY=openbenchml-super-secret-key-change-in-production-2024
LOG_LEVEL=INFO

# ─── Authentication ───────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
SECURE_COOKIES=False
COOKIE_SAMESITE=lax
BCRYPT_ROUNDS=12

# ─── Database ─────────────────────────────────────────────────────────────────
USE_SQLITE=True
DATABASE_URL=postgresql://openbenchml:openbenchml@localhost:5432/openbenchml
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Docker Sandbox ──────────────────────────────────────────────────────────
DOCKER_ENABLED=False
DOCKER_TIMEOUT=300

# ─── Benchmark Settings ──────────────────────────────────────────────────────
MAX_MODEL_SIZE_MB=500
BENCHMARK_TIMEOUT_SECONDS=300

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=True
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_BENCHMARK=5/minute

# ─── Caching ──────────────────────────────────────────────────────────────────
CACHE_ENABLED=True
CACHE_TTL_LEADERBOARD=60
CACHE_TTL_DATASETS=300
CACHE_TTL_STATS=30

# ─── GZip Compression ────────────────────────────────────────────────────────
GZIP_MIN_SIZE=1000

# ─── WebSocket ───────────────────────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=100
