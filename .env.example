# OpenBenchML Environment Configuration
# Copy this to .env and update values for production

# ─── Application ─────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# ─── Database ────────────────────────────────────────────────────────────────
# Use SQLite for development (no PostgreSQL needed)
USE_SQLITE=True
DATABASE_URL=postgresql://openbenchml:openbenchml@localhost:5432/openbenchml

# ─── Redis & Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Docker ──────────────────────────────────────────────────────────────────
DOCKER_ENABLED=False
DOCKER_TIMEOUT=300

# ─── Benchmark ───────────────────────────────────────────────────────────────
MAX_MODEL_SIZE_MB=500
BENCHMARK_TIMEOUT_SECONDS=300

# ─── Auth ────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
